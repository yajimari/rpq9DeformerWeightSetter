    global string $rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_optionVarNames[];

    if((`window -ex $windowName`)==true)deleteUI $windowName ;
    string $window = `window -t $windowName -mb true $windowName`;
    menu -l "Edit" ;
    menuItem -l "Save Settings" -c "rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_saveUiValues" ;
    menuItem -l "Reset Settings" -c "rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_deleteSavedUiValues();rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeightsOptions();" ;
    string $form = `formLayout`;
    string $column = `columnLayout -adj true`;
    separator -h 10 -st "none";
    float $floatMax = 3.402823466e+38;
    $rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_maxParamFieldName = `floatFieldGrp -numberOfFields 1 -label "maxParam: " -value1 $floatMax`;
    floatFieldGrp -e -cc ("clampFloatFieldGrpUnsigned(\"" + $rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_maxParamFieldName + "\"); rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_saveUiValues();") $rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_maxParamFieldName;

    $rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_thresholdSliderName = `floatSliderGrp -l "threshold: " -f true -min 0.0 -max 1.0 -pre 4 -v 0.001
    -cc "rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_saveUiValues();"`;

    $rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_findBackVertexMethodMenuName = `optionMenuGrp -label "findBackVertexMethod: " -cc "rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_saveUiValues();"`;
    menuItem -label "Scoring";
    menuItem -label "Raycast";
    separator -h 10 -st "none";
    setParent ..;

    string $button = `button -l "Apply" -h 40 -c "rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights()"`;
    formLayout -e
        -af $column "top" 0
        -af $column "left" 0
        -af $column "right" 0
        -ac $column "bottom" 0 $button

        -an $button "top"
        -af $button "left" 0
        -af $button "right" 0
        -af $button "bottom" 0
        $form;
    setParent ..;
    showWindow $window;

    rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_loadUiValues();
}


//--- scriptJob
global proc rpq9DeformerWeightSetter_selChangeSJ()
{
    global string $rpq9DeformerWeightSetter_prevSelected;
    global string $rpq9DeformerWeightSetter_currentDeformerName;
    string $deformerNames[] = rpq9DeformerWeightSetter_getSelDeformers();

    string $sel[] = `ls -sl`;
    if (size($sel) != 0){
        string $buffer[];
        tokenize $sel[0] "." $buffer;

        if($buffer[0] == $rpq9DeformerWeightSetter_prevSelected){
            return;
        }
        $rpq9DeformerWeightSetter_prevSelected = $buffer[0];
    }else{
        $rpq9DeformerWeightSetter_prevSelected = "";
    }

    rpq9DeformerWeightSetter_updateUi();
}


//--- reset global variables
proc rpq9DeformerWeightSetter_resetGlobalVariables()
{
    global string $rpq9DeformerWeightSetter_currentDeformerName;
    global string $rpq9DeformerWeightSetter_currentDeformerType;
    global int $rpq9DeformerWeightSetter_isSliderDragging;
