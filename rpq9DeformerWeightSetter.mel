    }
}


//--- rpq9MirrorSkinWeights
global proc clampFloatFieldGrpUnsigned(string $field)
{
    float $v = `floatFieldGrp -q -value1 $field`;
    float $floatMax = 3.402823466e+38;
    if ($v < 0.0)
        $v = 0.0;
    else if ($v > $floatMax)
        $v = $floatMax;

    floatFieldGrp -e -value1 $v $field;
}


global proc rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_saveUiValues()
{
    global string $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_mirrorSourceMenuName;
