    global string $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[];
    global string $rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_optionVarNames[];

    $rpq9DeformerWeightSetter_currentDeformerName = "";
    $rpq9DeformerWeightSetter_currentDeformerType = "";
    $rpq9DeformerWeightSetter_isSliderDragging = 0;
    $rpq9DeformerWeightSetter_prevSelected = "";
    $rpq9DeformerWeightSetter_optionVarNames = {"rpq9DeformerWeightSetter_setWeightModeRadioButtonValue", "rpq9DeformerWeightSetter_weightValueSliderValue"};
    $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames = {
        "rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_mirrorSourceMenuValue",
        "rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_sourceNamingConventionFieldText",
        "rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_targetNamingConventionFieldText",
        "rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_thresholdSliderValue"
    };
    $rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_optionVarNames = {
        "rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_maxParamFieldValue",
        "rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_thresholdSliderValue",
        "rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_findBackVertexMethodMenuValue"};
}


//--- main ui
global proc rpq9DeformerWeightSetter()
{
    string $windowName = "rpq9DeformerWeightSetter";
    //--- variable declaration
    global string $rpq9DeformerWeightSetter_deformerOptionName;
    global string $rpq9DeformerWeightSetter_influenceNameListFillterName;
    global string $rpq9DeformerWeightSetter_pinInfluenceNames[];
    global string $rpq9DeformerWeightSetter_pinInfluenceCacheNames[];
    global string $rpq9DeformerWeightSetter_influenceNameListName;
    global string $rpq9DeformerWeightSetter_influenceNameListSelNames[];
    global string $rpq9DeformerWeightSetter_influenceNameListPinName;
    global string $rpq9DeformerWeightSetter_influenceNameListPinMenuName;
    global int $rpq9DeformerWeightSetter_isInfluenceNameListPin;

    global string $rpq9DeformerWeightSetter_setWeightModeRadioButtonName;
    global string $rpq9DeformerWeightSetter_weightValueSliderName;

    global string $rpq9DeformerWeightSetter_currentDeformerName;
    global string $rpq9DeformerWeightSetter_currentDeformerType;
    global int $rpq9DeformerWeightSetter_isSliderDragging;
    global string $rpq9DeformerWeightSetter_prevSelected;

    global string $rpq9DeformerWeightSetter_optionVarNames[];

    rpq9DeformerWeightSetter_resetGlobalVariables();

    if((`window -ex $windowName`)==true)deleteUI $windowName ;
    string $window = `window -t $windowName -mb true $windowName` ;
    string $masterPane = `paneLayout -configuration "horizontal2"`;
    string $mainForm = `formLayout`;
    string $column1 = `columnLayout -adj true`;
    separator -h 10 -st "none";
    string $optionMenuForm = `formLayout`;
    $rpq9DeformerWeightSetter_deformerOptionName = `optionMenu -l "deformer: " -acc -cc "rpq9DeformerWeightSetter_deformerOptionCC(\"#1\")"`;
    formLayout -e   -af $rpq9DeformerWeightSetter_deformerOptionName "top" 0
                    -ap $rpq9DeformerWeightSetter_deformerOptionName "left" 0 20
                    -ap $rpq9DeformerWeightSetter_deformerOptionName "right" 0 80
                    -af $rpq9DeformerWeightSetter_deformerOptionName "bottom" 0
                    $optionMenuForm;
    setParent ..;// $optionMenuForm
    separator -h 10 -st "single" -hr true;
    frameLayout -l "Influences" -cll false;
    setParent ..;// frameLayout with "Inlfluences" label
    string $fillterRootLayout = `rowLayout -nc 2 -ad2 1`;
    setParent ..;// $fillterRootLayout
    setParent ..;// $column1

    $rpq9DeformerWeightSetter_influenceNameListName = `treeView -numberOfButtons 1 -abr false -arp false -editLabelCommand "" -scc rpq9DeformerWeightSetter_influenceListCC`;
    treeView -e -enableKeys true $rpq9DeformerWeightSetter_influenceNameListName;
    treeView -e -pressCommand 1 rpq9DeformerWeightSetter_influenceNameListLockCB $rpq9DeformerWeightSetter_influenceNameListName;

    string $fillterUiRoot = filterUICreateField($rpq9DeformerWeightSetter_influenceNameListName, $fillterRootLayout);

    string $fillterUiRootFullPath = `layout -q -fpn $fillterUiRoot`;
    string $fillterComponents[] = `layout -q -childArray $fillterUiRoot`;
    string $fillterTextFiled, $component;
    for ($component in $fillterComponents){
        if (`gmatch $component "textField*"`) {
            $fillterTextFiled = $component;
            break;
        }
    }
    $rpq9DeformerWeightSetter_influenceNameListFillterName = $fillterUiRootFullPath + "|" + $fillterTextFiled;

    $rpq9DeformerWeightSetter_influenceNameListPinName = `iconTextCheckBox -image "unpinned.png"  -w 20 -h 20`;

    iconTextCheckBox -e 
                    -onc ("rpq9DeformerWeightSetter_influenceNameListPinCallback "+$rpq9DeformerWeightSetter_influenceNameListPinName+" "+$rpq9DeformerWeightSetter_influenceNameListName+ " " + $rpq9DeformerWeightSetter_influenceNameListFillterName + " true")
                    -ofc ("rpq9DeformerWeightSetter_influenceNameListPinCallback "+$rpq9DeformerWeightSetter_influenceNameListPinName+" "+$rpq9DeformerWeightSetter_influenceNameListName+ " " + $rpq9DeformerWeightSetter_influenceNameListFillterName + " false")
                    $rpq9DeformerWeightSetter_influenceNameListPinName;
    $rpq9DeformerWeightSetter_influenceNameListPinMenuName = `popupMenu -p $rpq9DeformerWeightSetter_influenceNameListPinName`;
    rpq9DeformerWeightSetter_refleshInfluenceNameListPinMenu();
    setParent $mainForm;

    string $column2 = `columnLayout -adj true`;
    separator -h 10 -st "none";
    rowLayout -nc 5 -co5 5 5 5 5 5;
    //shelfLayout;
    int $buttonSize = 50;
    iconTextButton -h $buttonSize -w $buttonSize -st "iconAndTextVertical" -l "All" -i "Lock_ON.png" -c "rpq9DeformerWeightSetter_setAllSKinLiwFromUI(1)";
    iconTextButton -h $buttonSize -w $buttonSize -st "iconAndTextVertical" -l "All" -i "Lock_OFF_grey.png" -c "rpq9DeformerWeightSetter_setAllSKinLiwFromUI(0)";
    iconTextButton -h $buttonSize -w $buttonSize -st "iconAndTextVertical" -l "ByPoint" -i "copySkinWeight.png" -c "rpq9DeformerWeightSetter_copySelectedComponentWeightFromUI()";
    iconTextButton -h $buttonSize -w $buttonSize -st "iconAndTextVertical" -l "avg" -i "copySkinWeight.png" -c "rpq9DeformerWeightSetter_setSelectedComponentAverageWeightFromUI()";

    rowLayout -nc 2 -co2 5 5;
    iconTextButton -h $buttonSize -w $buttonSize -st "iconOnly" -i "copySkinWeight.png" -c "CopySkinWeights" -dcc "CopySkinWeightsOptions";
    iconTextButton -h $buttonSize -w $buttonSize -st "iconOnly" -i "mirrorSkinWeight.png" -c "rpq9DeformerWeightSetter_mirrorWeightsExecute()" -dcc "rpq9DeformerWeightSetter_mirrorWeightsOption()";

    setParent ..;// rowLayout
    setParent ..;// rowLayout

    if(!catchQuiet(`loadPlugin -qt "rpq9SkinningCommands"`)){
        rowLayout -nc 2 -co2 5 5;
        iconTextButton -h $buttonSize -w $buttonSize -st "iconAndTextVertical" -l "rpq9" -i "mirrorSkinWeight.png" -c "rpq9DeformerWeightSetter_rpq9MirrorSkinWeights()" -dcc "rpq9DeformerWeightSetter_rpq9MirrorSkinWeightsOptions";
        iconTextButton -h $buttonSize -w $buttonSize -st "iconAndTextVertical" -l "backVtx" -i "copySkinWeight.png" -c "rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights()" -dcc "rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeightsOptions";
        setParent ..;
    }

    separator -h 10 -st "single" -hr true;
    $rpq9DeformerWeightSetter_setWeightModeRadioButtonName = `radioButtonGrp -l "set weight mode: " -nrb 2 -sl 0 -la2 "absolute" "relative" -cc "rpq9DeformerWeightSetter_saveUiValues()"`;
    separator -h 10 -st "none";
    $rpq9DeformerWeightSetter_weightValueSliderName = `floatSliderButtonGrp -l "weights value: " -f true -min 0.0 -max 1.0 -pre 3 -bl "set weight"
     -dc "rpq9DeformerWeightSetter_sliderDC(\"#1\")" -cc "rpq9DeformerWeightSetter_slideCC(\"#1\"); rpq9DeformerWeightSetter_saveUiValues();" -bc rpq9DeformerWeightSetter_slideBC`;
    separator -h 10 -st "none";
    text -l "weight value buttons";
    separator -h 5 -st "single" -hr true;
    setParent ..;// $column2

    formLayout -e   -af $column1 "top" 0
                    -af $column1 "left" 0
                    -af $column1 "right" 0
                    -an $column1 "bottom"

                    -ac $rpq9DeformerWeightSetter_influenceNameListName "top" 0 $column1
                    -af $rpq9DeformerWeightSetter_influenceNameListName "left" 0
                    -af $rpq9DeformerWeightSetter_influenceNameListName "right" 0
                    -ac $rpq9DeformerWeightSetter_influenceNameListName "bottom" 0 $column2

                    -an $column2 "top"
                    -af $column2 "left" 0
                    -af $column2 "right" 0
                    -af $column2 "bottom" 0
                    $mainForm;
    setParent ..;// $mainForm

    string $buttonForm = `formLayout`;
    string $button1 = rpq9DeformerWeightSetter_createSetWeightButtons({0.0, 0.5, 0.05, 0.55, 0.001});
    string $button2 = rpq9DeformerWeightSetter_createSetWeightButtons({0.1, 0.6, 0.15, 0.65, 0.002});
    string $button3 = rpq9DeformerWeightSetter_createSetWeightButtons({0.2, 0.7, 0.25, 0.75, 0.01});
    string $button4 = rpq9DeformerWeightSetter_createSetWeightButtons({0.3, 0.8, 0.35, 0.85, 0.02});
    string $button5 = rpq9DeformerWeightSetter_createSetWeightButtons({0.4, 0.9, 0.45, 0.95, 1.0});

    formLayout  -e
                -af $button1 "top" 0
                -af $button1 "left" 0
                -ap $button1 "right" 0 20
                -af $button1 "bottom" 0
                
                -af $button2 "top" 0
                -ap $button2 "left" 0 20
                -ap $button2 "right" 0 40
                -af $button2 "bottom" 0
                
                -af $button3 "top" 0
                -ap $button3 "left" 0 40
                -ap $button3 "right" 0 60
                -af $button3 "bottom" 0
                
                -af $button4 "top" 0
                -ap $button4 "left" 0 60
                -ap $button4 "right" 0 80
                -af $button4 "bottom" 0
                
                -af $button5 "top" 0
                -ap $button5 "left" 0 80
                -af $button5 "right" 0
                -af $button5 "bottom" 0
                $buttonForm;
    setParent ..;// $buttonForm
    setParent ..;// $masterPane
    showWindow $window ;

    //--- post process
    iconTextCheckBox -e -v $rpq9DeformerWeightSetter_isInfluenceNameListPin $rpq9DeformerWeightSetter_influenceNameListPinName;
    rpq9DeformerWeightSetter_refleshInfluenceNameList($rpq9DeformerWeightSetter_influenceNameListPinName, $rpq9DeformerWeightSetter_influenceNameListName, $rpq9DeformerWeightSetter_influenceNameListFillterName, $rpq9DeformerWeightSetter_isInfluenceNameListPin);
    rpq9DeformerWeightSetter_loadUiValues();
    
    rpq9DeformerWeightSetter_selChangeSJ();
    scriptJob -event "SelectionChanged" "rpq9DeformerWeightSetter_selChangeSJ()" -per -p $window;
}