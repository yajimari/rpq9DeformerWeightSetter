global proc rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights()
{
    global string $rpq9DeformerWeightSetter_currentDeformerName;
    global string $rpq9DeformerWeightSetter_currentDeformerType;
    if ($rpq9DeformerWeightSetter_currentDeformerName == "") error "No selected deformer.";
    string $cmd = "";
    if($rpq9DeformerWeightSetter_currentDeformerType == "skinCluster"){
        $cmd += "rpq9CopyBackVertexSkinWeights";
        $cmd += rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_getFlagsFromOptionVar();
        $cmd += " -skinCluster \"" + $rpq9DeformerWeightSetter_currentDeformerName + "\"";
    }else{
        $cmd += "rpq9CopyBackVertexDeformerWeights";
        $cmd += rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeights_getFlagsFromOptionVar();
        $cmd += " -deformer \"" + $rpq9DeformerWeightSetter_currentDeformerName + "\"";
    }
    evalEcho($cmd);
}


global proc rpq9DeformerWeightSetter_rpq9CopyBackVertexSkinWeightsOptions()
{
    string $windowName = "rpq9CopyBackVertexSkinWeightsOptions";
    //--- variable declaration
