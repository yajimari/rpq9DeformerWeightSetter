global proc int rpq9DeformerWeightSetter_checkTrackSelectionOrder()
{
    int $isTrackSelectionOrder = `selectPref -q -tso`;
    if(!$isTrackSelectionOrder) warning "The track selection order is not active.";
    return $isTrackSelectionOrder;
}


global proc rpq9DeformerWeightSetter_setWeight(string $components[], float $value)
{
    global string $rpq9DeformerWeightSetter_currentDeformerName;
    global string $rpq9DeformerWeightSetter_currentDeformerType;
    if ($rpq9DeformerWeightSetter_currentDeformerName == "") error "No selected deformer.";

    global string $rpq9DeformerWeightSetter_setWeightModeRadioButtonName;
    int $setMode = `radioButtonGrp -q -sl $rpq9DeformerWeightSetter_setWeightModeRadioButtonName`;

    if($rpq9DeformerWeightSetter_currentDeformerType == "skinCluster"){
        global string $rpq9DeformerWeightSetter_influenceNameListName;
        string $joints[] = `treeView -q -si $rpq9DeformerWeightSetter_influenceNameListName`;
        if(`size($joints)` == 0) error "No selected influence.";
        skinPercent -tv $joints[0] $value -r ($setMode-1) $rpq9DeformerWeightSetter_currentDeformerName $components;
    }else{
        if (($setMode-1) == 0){
            percent -v $value $rpq9DeformerWeightSetter_currentDeformerName $components;
        }else{
            percent -v $value -ap $rpq9DeformerWeightSetter_currentDeformerName $components;
        }
    }
}


global proc rpq9DeformerWeightSetter_setWeightToSelected(float $value){
    string $sel[] = `ls -os -fl`;
    if(`size($sel)` == 0)  error "No selected.";
    rpq9DeformerWeightSetter_setWeight($sel, $value);
}


global proc rpq9DeformerWeightSetter_copyComponentWeight(string $sourceComponent, string $targetComponents[])
{
    global string $rpq9DeformerWeightSetter_currentDeformerName;
    global string $rpq9DeformerWeightSetter_currentDeformerType;
    if ($rpq9DeformerWeightSetter_currentDeformerName == "") error "No selected deformer.";

    int $i=0;
    if($rpq9DeformerWeightSetter_currentDeformerType == "skinCluster"){
        string $influences[] = `skinPercent -q -transform $rpq9DeformerWeightSetter_currentDeformerName $sourceComponent`;
        float $values[] = `skinPercent -q -v $rpq9DeformerWeightSetter_currentDeformerName $sourceComponent`;

        string $commandBase = "skinPercent -nrm false -zri true ";
        for($i=0; $i<size($influences); ++$i){
            $commandBase += "-tv " + $influences[$i] + " " + $values[$i] + " ";
        }
        $commandBase += $rpq9DeformerWeightSetter_currentDeformerName + " ";
        
        for($i=0; $i<size($targetComponents); ++$i){
            if(catchQuiet(eval ($commandBase + $targetComponents[$i]))){
                warning ("skipped copy " + $targetComponents[$i]);
            }
        }
    }else{
        float $value = `percent -q -v $rpq9DeformerWeightSetter_currentDeformerName $sourceComponent`;
        string $commandBase = "percent -v " + $value + " " + $rpq9DeformerWeightSetter_currentDeformerName + " ";
        for($i=0; $i<size($targetComponents); ++$i){
            if(catchQuiet(eval ($commandBase + $targetComponents[$i]))){
                warning ("skipped copy " + $targetComponents[$i]);
            }
        }
    }
}


global proc rpq9DeformerWeightSetter_copySelectedComponentWeight(){
    rpq9DeformerWeightSetter_checkTrackSelectionOrder();
    string $sel[] = `ls -os -fl`;
    if(`size($sel)` < 2)  error "Worng number of selected.";
    string $source = $sel[0];
    stringArrayRemoveAtIndex(0, $sel);
    rpq9DeformerWeightSetter_copyComponentWeight($source, $sel);
}


global proc rpq9DeformerWeightSetter_setAverageWeight(string $sourceComponents[], string $targetComponent)
{
    global string $rpq9DeformerWeightSetter_currentDeformerName;
    global string $rpq9DeformerWeightSetter_currentDeformerType;
    if ($rpq9DeformerWeightSetter_currentDeformerName == "") error "No selected deformer.";

    int $i=0;
    int $j=0;
    int $sourceComponentNum = size($sourceComponents);

    if($rpq9DeformerWeightSetter_currentDeformerType == "skinCluster"){
        string $influences[] = `skinPercent -q -transform $rpq9DeformerWeightSetter_currentDeformerName $targetComponent`;
        int $influenceNum = size($influences);

        float $influenceCache[] = {};
        for($i=0; $i<$sourceComponentNum; ++$i){
            float $values[] = `skinPercent -q -v $rpq9DeformerWeightSetter_currentDeformerName $sourceComponents[$i]`;
            for($j=0; $j<$influenceNum; ++$j){
                $influenceCache[$j] += $values[$j];
            }
        }

        for($j=0; $j<$influenceNum; ++$j){
                $influenceCache[$j] /= $sourceComponentNum;
        }

        string $commandBase = "skinPercent -nrm false -zri true ";
        for($i=0; $i<$influenceNum; ++$i){
            $commandBase += "-tv " + $influences[$i] + " " + $influenceCache[$i] + " ";
        }
        $commandBase += $rpq9DeformerWeightSetter_currentDeformerName + " ";

        catchQuiet(eval ($commandBase + $targetComponent));
    }else{
        float $value = 0.0;
        for($i=0; $i<$sourceComponentNum; ++$i){
            $value += `percent -q -v $rpq9DeformerWeightSetter_currentDeformerName $sourceComponents[$i]`;
        }

        $value /= $sourceComponentNum;
        percent -v $value $rpq9DeformerWeightSetter_currentDeformerName $targetComponent;
    }
}


global proc rpq9DeformerWeightSetter_setSelectedComponentAverageWeight(){
    rpq9DeformerWeightSetter_checkTrackSelectionOrder();
    string $sel[] = `ls -os -fl`;
    int $selNum = `size($sel)`;
    if($selNum < 2)  error "Worng number of selected.";
    string $target = $sel[$selNum - 1];
    stringArrayRemoveAtIndex($selNum - 1, $sel);
    rpq9DeformerWeightSetter_setAverageWeight($sel, $target);
}


global proc string[] rpq9DeformerWeightSetter_getSelDeformers()
{
    string $sel[] = `ls -os`;
    if (`size($sel)` == 0){
        return {};
    }
    string $history[] = `listHistory $sel[0]`;
    string $deformers[] = `ls -type "geometryFilter" $history `;
    string $deformer;
    string $resultDeformer[];
    for ($deformer in $deformers){
        if(`nodeType $deformer` != "tweak"){
            $resultDeformer[`size($resultDeformer)`] = $deformer;
        }
    }
    return $resultDeformer;
}


//--- ui creater
proc string rpq9DeformerWeightSetter_createSetWeightButtons(float $buttonValues[])
{
    int $i = 0;
    string $form = `formLayout`;
    string $button;
    string $buttonValueString = "";
    int $buttonNum = `size($buttonValues)`;
    for ($i=0; $i<$buttonNum; $i++){
        $buttonValueString = `python ("str(float(" + $buttonValues[$i] + "))")`;
        $button = `button -l $buttonValueString -c ("rpq9DeformerWeightSetter_setWeightToSelected(" + $buttonValueString + ")")`;
        formLayout -e   -af $button "left" 0
                        -af $button "right" 0
                        $form;
        if ($i==0){
            formLayout -e   -af $button "top" 0
                            -ap $button "bottom" 0 (100/$buttonNum)
                            $form;
        }else if ($i==$buttonNum-1){
            formLayout -e   -ap $button "top" 0 ($i*100/$buttonNum)
                            -af $button "bottom" 0
                            $form;
        }else{
            formLayout -e   -ap $button "top" 0 ($i*100/$buttonNum)
                            -ap $button "bottom" 0 (($i+1)*100/$buttonNum)
                            $form;
        }
    }
    setParent ..;
    return $form;
}


global proc rpq9DeformerWeightSetter_setListLockIcon(string $item, int $lockValue)
{
    global string $rpq9DeformerWeightSetter_influenceNameListName;
    treeView -e -buttonVisible $item 1 1 $rpq9DeformerWeightSetter_influenceNameListName;
    string $icon = ($lockValue)? "Lock_ON.png" : "Lock_OFF_grey.png";
    treeView -e -i $item 1 $icon $rpq9DeformerWeightSetter_influenceNameListName;
}


//--- ui updater
global proc rpq9DeformerWeightSetter_updateSelectionDeformerList()
{
    int $i = 0;
    global string $rpq9DeformerWeightSetter_deformerOptionName;
    global string $rpq9DeformerWeightSetter_currentDeformerName;
    global string $rpq9DeformerWeightSetter_currentDeformerType;

    int $currentListItemNum = `optionMenu -q -ni $rpq9DeformerWeightSetter_deformerOptionName`;
    if($currentListItemNum == 0){
        return;
    }
    string $currentDeformerListItems[] = `optionMenu -q -ill $rpq9DeformerWeightSetter_deformerOptionName`;
    string $currentDeformerList[];
    if(`size($currentDeformerListItems)`){
        for($i=0; $i<`size($currentDeformerListItems)`; $i++){
            $currentDeformerList[$i] = `menuItem -q -l $currentDeformerListItems[$i]`;
        }
    }

    if (`stringArrayContains $rpq9DeformerWeightSetter_currentDeformerName $currentDeformerList`){
        optionMenu -e -v $rpq9DeformerWeightSetter_currentDeformerName $rpq9DeformerWeightSetter_deformerOptionName;
    }else{
        string $currentDeformer = `optionMenu -q -v $rpq9DeformerWeightSetter_deformerOptionName`;
        if ($currentDeformer != ""){
            $rpq9DeformerWeightSetter_currentDeformerName = $currentDeformer;
            $rpq9DeformerWeightSetter_currentDeformerType = `nodeType $currentDeformer`;
        }
    }
}


global proc rpq9DeformerWeightSetter_updateDeformerList()
{
    global string $rpq9DeformerWeightSetter_deformerOptionName;
    global string $rpq9DeformerWeightSetter_currentDeformerName;
    global string $rpq9DeformerWeightSetter_currentDeformerType;

    string $deformerNames[] = rpq9DeformerWeightSetter_getSelDeformers();

    optionMenu -e -dai $rpq9DeformerWeightSetter_deformerOptionName;
    if (`size($deformerNames)` != 0){
        string $deformerName;
        for ($deformerName in $deformerNames){
            menuItem -l $deformerName -p $rpq9DeformerWeightSetter_deformerOptionName;
        }
    }
    rpq9DeformerWeightSetter_updateSelectionDeformerList();
}


global proc rpq9DeformerWeightSetter_updateInfluenceNameListvisible()
{
    global string $rpq9DeformerWeightSetter_influenceNameListName;
    global int $rpq9DeformerWeightSetter_isInfluenceNameListPin;
    string $items[] = `treeView -q -children "" $rpq9DeformerWeightSetter_influenceNameListName`;
    if($rpq9DeformerWeightSetter_isInfluenceNameListPin){
        global string $rpq9DeformerWeightSetter_pinInfluenceNames[];
        for( $item in $items ){
            int $lVisible = false;

            for( $pinItem in $rpq9DeformerWeightSetter_pinInfluenceNames){
                if( $pinItem == $item ){
                    $lVisible = true;
                    break;
                }
            }
            treeView -e -itemVisible $item $lVisible $rpq9DeformerWeightSetter_influenceNameListName;
        }
    }else{
        for( $item in $items ){
            treeView -e -itemVisible $item true $rpq9DeformerWeightSetter_influenceNameListName;
        }
    }
}


global proc rpq9DeformerWeightSetter_updateInfluenceList()
{
    global string $rpq9DeformerWeightSetter_deformerOptionName;
    global string $rpq9DeformerWeightSetter_influenceNameListFillterName;
    global string $rpq9DeformerWeightSetter_influenceNameListPinName;
    global string $rpq9DeformerWeightSetter_influenceNameListName;
    global string $rpq9DeformerWeightSetter_influenceNameListSelNames[];
    global string $rpq9DeformerWeightSetter_currentDeformerName;
    global string $rpq9DeformerWeightSetter_currentDeformerType;

    treeView -e -ra $rpq9DeformerWeightSetter_influenceNameListName;

    if (`optionMenu -q -ni $rpq9DeformerWeightSetter_deformerOptionName` == 0) return;

    if ($rpq9DeformerWeightSetter_currentDeformerType == "skinCluster"){
        string $influences[] = `skinCluster -q -inf $rpq9DeformerWeightSetter_currentDeformerName`;
        string $influence;
        for ($influence in $influences){
            treeView -e -ai $influence "" $rpq9DeformerWeightSetter_influenceNameListName;
            rpq9DeformerWeightSetter_setListLockIcon($influence, `getAttr($influence + ".liw")`);
        }
        filterUIHandleField $rpq9DeformerWeightSetter_influenceNameListName $rpq9DeformerWeightSetter_influenceNameListFillterName;

        if (size($rpq9DeformerWeightSetter_influenceNameListSelNames) != 0){
            string $c;
            for ($c in $rpq9DeformerWeightSetter_influenceNameListSelNames){
                if(`stringArrayContains $c $influences`){
                    treeView -e -si $c 1 $rpq9DeformerWeightSetter_influenceNameListName;
                }
            }
        }
    }

    if(`iconTextCheckBox -q -v $rpq9DeformerWeightSetter_influenceNameListPinName`){
        rpq9DeformerWeightSetter_updateInfluenceNameListvisible();
    }

    rpq9DeformerWeightSetter_influenceListCC();
}


global proc rpq9DeformerWeightSetter_updateUi()
{
    rpq9DeformerWeightSetter_updateDeformerList();
    rpq9DeformerWeightSetter_updateInfluenceList();
}


//---ui command
global proc rpq9DeformerWeightSetter_influenceNameListLockCB(string $item, int $buttonState)
{
    global string $rpq9DeformerWeightSetter_influenceNameListName;
    int $lockValue = 0;
    if (`attributeQuery -n $item -ex liw`){
        $lockValue = (`getAttr ( $item + ".liw" )`)? 0 : 1;
        setAttr ($item + ".liw") $lockValue;
    }
    rpq9DeformerWeightSetter_setListLockIcon($item, $lockValue);

    string $selections[] = `treeView -q -si $rpq9DeformerWeightSetter_influenceNameListName`;
    if (stringArrayContains($item, $selections)){
        for ($s in $selections){
            if (`attributeQuery -n $s -ex liw`){
                setAttr ($s + ".liw") $lockValue;
            }
            rpq9DeformerWeightSetter_setListLockIcon($s, $lockValue);
        }
    }
}


global proc rpq9DeformerWeightSetter_refleshInfluenceNameList(string $pinButton, string $treeView, string $fillterField, int $pPressed)
{
    global int $rpq9DeformerWeightSetter_isInfluenceNameListPin;
    $rpq9DeformerWeightSetter_isInfluenceNameListPin = $pPressed;
    rpq9DeformerWeightSetter_updateInfluenceNameListvisible();

    if( $pPressed ){
        textField -e -en false $fillterField;
        iconTextCheckBox -e -image "pinned.png" $pinButton;
    }else{
        textField -e -en true $fillterField;
        iconTextCheckBox -e -image "unpinned.png" $pinButton;
        filterUIHandleField $treeView $fillterField;
    }
}


global proc rpq9DeformerWeightSetter_influenceNameListPinCallback(string $pinButton, string $treeView, string $fillterField, int $pPressed)
{
    global string $rpq9DeformerWeightSetter_pinInfluenceNames[];
    
    if( $pPressed ){
        $rpq9DeformerWeightSetter_pinInfluenceNames = `treeView -q -si $treeView`;
    }else{
        $rpq9DeformerWeightSetter_pinInfluenceNames = {};
    }
    rpq9DeformerWeightSetter_refleshInfluenceNameList($pinButton, $treeView, $fillterField, $pPressed);
}


global proc rpq9DeformerWeightSetter_influenceNameListPinUnlockAll()
{
    global string $rpq9DeformerWeightSetter_influenceNameListPinName;
    global string $rpq9DeformerWeightSetter_influenceNameListFillterName;
    global string $rpq9DeformerWeightSetter_influenceNameListName;
    global string $rpq9DeformerWeightSetter_pinInfluenceNames[];
    $rpq9DeformerWeightSetter_pinInfluenceNames = {};
    global int $rpq9DeformerWeightSetter_isInfluenceNameListPin;

    string $items[] = `treeView -q -children "" $rpq9DeformerWeightSetter_influenceNameListName`;
    string $item;
    for($item in $items){
        if(`getAttr ($item + ".liw")` == 0){
            $rpq9DeformerWeightSetter_pinInfluenceNames[size($rpq9DeformerWeightSetter_pinInfluenceNames)] = $item;
        }
    }
    $rpq9DeformerWeightSetter_isInfluenceNameListPin = true;
    rpq9DeformerWeightSetter_updateInfluenceNameListvisible();

    textField -e -en false $rpq9DeformerWeightSetter_influenceNameListFillterName;
    iconTextCheckBox -e -image "pinned.png" -v true $rpq9DeformerWeightSetter_influenceNameListPinName;
}


global proc rpq9DeformerWeightSetter_applyInfluenceNameListCachePin(string $cacheName)
{
    global string $rpq9DeformerWeightSetter_influenceNameListPinName;
    global string $rpq9DeformerWeightSetter_influenceNameListFillterName;
    global int $rpq9DeformerWeightSetter_isInfluenceNameListPin;
    string $globalVaraiableName = "rpq9DeformerWeightSetter_influenceNameListCachePin_" + $cacheName;

    string $cmd = "global string $" + $globalVaraiableName + "[]; global string $rpq9DeformerWeightSetter_pinInfluenceNames[]; $rpq9DeformerWeightSetter_pinInfluenceNames = $" + $globalVaraiableName + ";";
    eval($cmd);
    $rpq9DeformerWeightSetter_isInfluenceNameListPin = true;
    rpq9DeformerWeightSetter_updateInfluenceNameListvisible();

    textField -e -en false $rpq9DeformerWeightSetter_influenceNameListFillterName;
    iconTextCheckBox -e -image "pinned.png" -v true $rpq9DeformerWeightSetter_influenceNameListPinName;
}


global proc rpq9DeformerWeightSetter_refleshInfluenceNameListPinMenu()
{
    global string $rpq9DeformerWeightSetter_influenceNameListPinName;
    global string $rpq9DeformerWeightSetter_influenceNameListPinMenuName;
    global string $rpq9DeformerWeightSetter_pinInfluenceCacheNames[];

    popupMenu -e -dai $rpq9DeformerWeightSetter_influenceNameListPinMenuName;
    menuItem -l "Unlock All" -c "rpq9DeformerWeightSetter_influenceNameListPinUnlockAll" -p $rpq9DeformerWeightSetter_influenceNameListPinMenuName;
    menuItem -divider true -p $rpq9DeformerWeightSetter_influenceNameListPinMenuName;
    menuItem -l "Cache Pin" -c "rpq9DeformerWeightSetter_influenceNameListCachePin" -p $rpq9DeformerWeightSetter_influenceNameListPinMenuName;
    menuItem -l "Delete Cache Pin" -c "rpq9DeformerWeightSetter_influenceNameListDeleteCachePin" -p $rpq9DeformerWeightSetter_influenceNameListPinMenuName;
    menuItem -divider true -p $rpq9DeformerWeightSetter_influenceNameListPinMenuName;
    string $name = "";
    for($name in $rpq9DeformerWeightSetter_pinInfluenceCacheNames){
        menuItem -l $name -c ("rpq9DeformerWeightSetter_applyInfluenceNameListCachePin " + $name) -p $rpq9DeformerWeightSetter_influenceNameListPinMenuName;
    }
}


global proc rpq9DeformerWeightSetter_influenceNameListCachePin()
{
    global string $rpq9DeformerWeightSetter_pinInfluenceNames[];
    global string $rpq9DeformerWeightSetter_pinInfluenceCacheNames[];
    global int $rpq9DeformerWeightSetter_isInfluenceNameListPin;

    if (`size($rpq9DeformerWeightSetter_pinInfluenceNames)` < 1) error("Current influence list has not pinned influence.");

    string $text = "";
    string $result =    `promptDialog
                        -title "Influence List Pin Cache"
                        -message "Enter Cache Name:"
                        -button "OK" -button "Cancel"
                        -defaultButton "OK" -cancelButton "Cancel"
                        -dismissString "Cancel"`;

    if ($result == "OK") {
        $text = `promptDialog -q -text`;
    }else{
        return;
    }

    if(`gmatch $text "*[!a-zA-Z0-9]*"`) error("\"" + $text + "\" has non alphanumeric.");

    int $cacheIndex = stringArrayFind($text, 0, $rpq9DeformerWeightSetter_pinInfluenceCacheNames);
    if ($cacheIndex<0){
        $cacheIndex = `size($rpq9DeformerWeightSetter_pinInfluenceCacheNames)`;
        $rpq9DeformerWeightSetter_pinInfluenceCacheNames[$cacheIndex] = $text;
    }
    string $globalVaraiableName = "rpq9DeformerWeightSetter_influenceNameListCachePin_" + $text;

    string $cmd = "global string $" + $globalVaraiableName + "[]; $" + $globalVaraiableName + "={\"";
    $cmd += stringArrayToString($rpq9DeformerWeightSetter_pinInfluenceNames, "\",\"");
    $cmd += "\"};";

    eval($cmd);
    rpq9DeformerWeightSetter_refleshInfluenceNameListPinMenu();
}


global proc rpq9DeformerWeightSetter_influenceNameListDeleteCachePinDialogTreeSCC(string $treeView)
{
    global string $rpq9DeformerWeightSetter_influenceNameListDeleteCachePinDialogTreeSelected[];
    $rpq9DeformerWeightSetter_influenceNameListDeleteCachePinDialogTreeSelected =  `treeView -q -selectItem $treeView`;
}


global proc rpq9DeformerWeightSetter_influenceNameListDeleteCachePinDialogUI()
{
    global string $rpq9DeformerWeightSetter_pinInfluenceCacheNames[];
    global string $rpq9DeformerWeightSetter_influenceNameListDeleteCachePinDialogTreeSelected[];
    $rpq9DeformerWeightSetter_influenceNameListDeleteCachePinDialogTreeSelected = {};

    string $form = `setParent -q`;

    string $tree = `treeView -abr false -arp false -editLabelCommand ""`;
    treeView -e -scc ("rpq9DeformerWeightSetter_influenceNameListDeleteCachePinDialogTreeSCC " + $tree) $tree;
    string $cacheName = "";
    for($cacheName in $rpq9DeformerWeightSetter_pinInfluenceCacheNames){
        treeView -e -ai $cacheName "" $tree;
    }
    string $applyButton = `button -l "Apply" -c "layoutDialog -dismiss \"Apply\""`;
    string $cancelButton = `button -l "Cancel" -c "layoutDialog -dismiss \"Cancel\""`;

    formLayout -e
        -af $tree "top" 0
        -af $tree "left" 0
        -af $tree "right" 0
        -ac $tree "bottom" 0 $applyButton

        -an $applyButton "top"
        -af $applyButton "left" 0
        -ap $applyButton "right" 0 50
        -af $applyButton "bottom" 0

        -an $cancelButton "top"
        -ap $cancelButton "left" 0 50
        -af $cancelButton "right" 0
        -af $cancelButton "bottom" 0

        $form;
}


global proc rpq9DeformerWeightSetter_influenceNameListDeleteCachePin()
{
    global string $rpq9DeformerWeightSetter_pinInfluenceCacheNames[];
    global string $rpq9DeformerWeightSetter_influenceNameListDeleteCachePinDialogTreeSelected[];
    string $deleteCacheNames = `layoutDialog  -t "Delete Pin Cache"-ui "rpq9DeformerWeightSetter_influenceNameListDeleteCachePinDialogUI"`;
    if($deleteCacheNames != "Apply") return;

    string $item = "";
    for($item in $rpq9DeformerWeightSetter_influenceNameListDeleteCachePinDialogTreeSelected){
        int $cacheIndex = stringArrayFind($item, 0, $rpq9DeformerWeightSetter_pinInfluenceCacheNames);

        string $globalVaraiableName = "rpq9DeformerWeightSetter_influenceNameListCachePin_" + $item;
        string $cmd = "global string $" + $globalVaraiableName + "[]; $" + $globalVaraiableName + "={};";
        eval($cmd);

        stringArrayRemoveAtIndex($cacheIndex, $rpq9DeformerWeightSetter_pinInfluenceCacheNames);
    }
    $rpq9DeformerWeightSetter_influenceNameListDeleteCachePinDialogTreeSelected = {};
    rpq9DeformerWeightSetter_refleshInfluenceNameListPinMenu();
}


global proc rpq9DeformerWeightSetter_deformerOptionCC(string $current)
{
    global string $rpq9DeformerWeightSetter_currentDeformerName;
    global string $rpq9DeformerWeightSetter_currentDeformerType;
    $rpq9DeformerWeightSetter_currentDeformerName = $current;
    $rpq9DeformerWeightSetter_currentDeformerType = `nodeType $current`;
    rpq9DeformerWeightSetter_updateInfluenceList();
}


global proc rpq9DeformerWeightSetter_influenceListCC()
{
    global string $rpq9DeformerWeightSetter_prevBorderHighliteItem;
    global string $rpq9DeformerWeightSetter_influenceNameListName;
    global string $rpq9DeformerWeightSetter_influenceNameListSelNames[];
    if($rpq9DeformerWeightSetter_prevBorderHighliteItem != "" && `treeView -q -iex $rpq9DeformerWeightSetter_prevBorderHighliteItem $rpq9DeformerWeightSetter_influenceNameListName`){
        treeView -e -bh $rpq9DeformerWeightSetter_prevBorderHighliteItem false $rpq9DeformerWeightSetter_influenceNameListName;
    }

    $rpq9DeformerWeightSetter_influenceNameListSelNames = `treeView -q -si $rpq9DeformerWeightSetter_influenceNameListName`;
    if (`size ($rpq9DeformerWeightSetter_influenceNameListSelNames)` >= 2 ){
        $rpq9DeformerWeightSetter_prevBorderHighliteItem = $rpq9DeformerWeightSetter_influenceNameListSelNames[0];
        treeView -e -bh $rpq9DeformerWeightSetter_influenceNameListSelNames[0] true $rpq9DeformerWeightSetter_influenceNameListName;
    }
}


global proc rpq9DeformerWeightSetter_setAllSKinLiwFromUI(int $value)
{
    global string $rpq9DeformerWeightSetter_influenceNameListName;
    string $influences[] = `treeView -q -children "" $rpq9DeformerWeightSetter_influenceNameListName`;
    if (`size($influences)` == 0) return;

    string $influence;
    undoInfo -openChunk -chunkName "rpq9DeformerWeightSetter_setAllSKinLiw";
    for($influence in $influences){
        if (`attributeQuery -node $influence -exists "liw"`) {
            setAttr ($influence + ".liw") $value;
            rpq9DeformerWeightSetter_setListLockIcon($influence, $value);
        }
    }
    undoInfo -closeChunk;
}


global proc rpq9DeformerWeightSetter_sliderDC(float $value)
{
    global string $rpq9DeformerWeightSetter_weightValueSliderName;
    global int $rpq9DeformerWeightSetter_isSliderDragging;
    if ($rpq9DeformerWeightSetter_isSliderDragging == 0){
        undoInfo -openChunk -chunkName "rpq9DeformerWeightSetter_sliderDrag";
        $rpq9DeformerWeightSetter_isSliderDragging = 1;
    }
    catch(rpq9DeformerWeightSetter_setWeightToSelected($value));
}


global proc rpq9DeformerWeightSetter_slideCC(float $value)
{
    global string $rpq9DeformerWeightSetter_weightValueSliderName;
    global int $rpq9DeformerWeightSetter_isSliderDragging;

    catch(rpq9DeformerWeightSetter_setWeightToSelected($value));

    if ($rpq9DeformerWeightSetter_isSliderDragging == 1){
        undoInfo -closeChunk;
        $rpq9DeformerWeightSetter_isSliderDragging = 0;
    }
}


global proc rpq9DeformerWeightSetter_slideBC()
{
    global string $rpq9DeformerWeightSetter_weightValueSliderName;

    float $value = `floatSliderButtonGrp -q -v $rpq9DeformerWeightSetter_weightValueSliderName`;
    rpq9DeformerWeightSetter_setWeightToSelected($value);
}


