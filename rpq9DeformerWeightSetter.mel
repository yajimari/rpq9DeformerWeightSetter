global proc string rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_getFlagsFromOptionVar()
{
    global string $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[];
    string $cmd = "";
    if(`optionVar -exists $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[0]`){
        $cmd += " -mirrorSource " + (`optionVar -q $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[0]` - 1);
    }
    if(`optionVar -exists $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[1]` && `optionVar -exists $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[2]`){
        string $sourceText = `optionVar -q $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[1]`;
        string $targetText = `optionVar -q $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[2]`;
        if($sourceText != "" && $targetText != ""){
            $cmd += " -namingConvention \"" + $sourceText + "\" \"" + $targetText + "\"";
        }
    }
    if(`optionVar -exists $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[3]`){
        $cmd += " -threshold " + `optionVar -q $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[3]`;
    }
    return $cmd;
}


global proc rpq9DeformerWeightSetter_rpq9MirrorSkinWeights()
{
    global string $rpq9DeformerWeightSetter_currentDeformerName;
    global string $rpq9DeformerWeightSetter_currentDeformerType;
    if ($rpq9DeformerWeightSetter_currentDeformerName == "") error "No selected deformer.";
    if($rpq9DeformerWeightSetter_currentDeformerType != "skinCluster") error "current deformer is not skinCluster.";

    string $cmd = "rpq9MirrorSkinWeights";
    $cmd += rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_getFlagsFromOptionVar();
    $cmd += " -skinCluster \"" + $rpq9DeformerWeightSetter_currentDeformerName + "\"";

    evalEcho($cmd);
}


global proc rpq9DeformerWeightSetter_rpq9MirrorSkinWeightsOptions()
{
    string $windowName = "rpq9MirrorSkinWeightsOptions";
    //--- variable declaration
    global string $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_mirrorSourceMenuName;
    global string $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_sourceNamingConventionFieldName;
    global string $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_targetNamingConventionFieldName;
    global string $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_thresholdSliderName;
    global string $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[];

    if((`window -ex $windowName`)==true)deleteUI $windowName ;
    string $window = `window -t $windowName -mb true $windowName` ;
    menu -l "Edit" ;
    menuItem -l "Save Settings" -c "rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_saveUiValues" ;
    menuItem -l "Reset Settings" -c "rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_deleteSavedUiValues();rpq9DeformerWeightSetter_rpq9MirrorSkinWeightsOptions();" ;
    string $form = `formLayout`;
    string $column = `columnLayout -adj true`;
    separator -h 10 -st "none";
    $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_mirrorSourceMenuName = `optionMenuGrp -label "mirrorSource: " -cc "rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_saveUiValues();"`;
    menuItem -label "x";
    menuItem -label "y";
    menuItem -label "z";
    menuItem -label "-x";
    menuItem -label "-y";
    menuItem -label "-z";
    separator -h 10 -st "none";

    $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_sourceNamingConventionFieldName = `textFieldGrp -label "sourceNamingConvention: " -cc "rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_saveUiValues()"`;
    $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_targetNamingConventionFieldName = `textFieldGrp -label "targetNamingConvention: " -cc "rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_saveUiValues()"`;
    
    $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_thresholdSliderName = `floatSliderGrp -l "threshold: " -f true -min 0.0 -max 1.0 -pre 4 -v 0.001
    -cc "rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_saveUiValues();"`;
    separator -h 10 -st "none";
    setParent ..;

    string $button = `button -l "Apply" -h 40 -c "rpq9DeformerWeightSetter_rpq9MirrorSkinWeights()"`;
    formLayout -e
        -af $column "top" 0
        -af $column "left" 0
        -af $column "right" 0
        -ac $column "bottom" 0 $button

        -an $button "top"
        -af $button "left" 0
        -af $button "right" 0
        -af $button "bottom" 0
        $form;
    setParent ..;
    showWindow $window;

    rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_loadUiValues();
}


