    global string $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_thresholdSliderName;
    global string $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[];
    optionVar -iv $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[0] `optionMenuGrp -q -sl $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_mirrorSourceMenuName`;
    optionVar -sv $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[1] `textFieldGrp -q -tx $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_sourceNamingConventionFieldName`;
    optionVar -sv $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[2] `textFieldGrp -q -tx $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_targetNamingConventionFieldName`;
    optionVar -fv $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_optionVarNames[3] `floatSliderGrp -q -v $rpq9DeformerWeightSetter_rpq9MirrorSkinWeights_thresholdSliderName`;
    
}


